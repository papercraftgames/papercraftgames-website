---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const games = (await getCollection('games')).sort((a, b) => a.data.order - b.data.order);
const featured = games.find((game) => game.data.featured) ?? games[0];
const home = await getEntry('site', 'home');
const homeData = home?.data ?? {
  title: 'Papercraft Games',
  eyebrow: 'Cozy handmade games, built in paper layers',
  lede: 'We make small, tactile adventures with cozy spaces, playful interactions, and the Folded Paper Engine toolchain behind the scenes.',
  itchUrl: 'https://papercraft-games.itch.io/',
  fpeUrl: 'https://foldedpaperengine.com',
};
---

<BaseLayout
  title={homeData.title}
  description="Cozy handmade games and open-source tools from Papercraft Games."
>
  <header class="site-header" aria-label="Site header">
    <a class="brand" href="/" aria-label="Papercraft Games home">
      <img src="/images/papercraft-games-logo.png" alt="Papercraft Games" />
    </a>
    <nav class="top-nav" aria-label="Primary navigation">
      <a href="#games">Games</a>
      <a href="#engine">FPE</a>
      <a href={homeData.itchUrl} target="_blank" rel="noopener noreferrer">Itch.io</a>
      <a href="/admin/">CMS</a>
    </nav>
  </header>

  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-art" aria-hidden="true">
        <img src={featured.data.heroImage} alt="" />
      </div>
      <div class="hero-copy">
        <p class="eyebrow">{homeData.eyebrow}</p>
        <h1 id="hero-title">{homeData.title}</h1>
        <p class="lede">{homeData.lede}</p>
        <div class="hero-actions">
          <a class="button primary" href="#games">Explore games</a>
          <a class="button secondary" href={homeData.itchUrl} target="_blank" rel="noopener noreferrer">
            Visit Itch.io
          </a>
        </div>
      </div>
    </section>

    <section id="games" class="section games-section" aria-labelledby="games-title">
      <div class="section-heading">
        <p class="eyebrow">In development</p>
        <h2 id="games-title">Small worlds with useful details</h2>
      </div>

      <div class="game-list">
        {
          games.map((game) => (
            <article class="game-panel" id={game.id}>
              <div class="game-copy">
                <p class="status">{game.data.status}</p>
                <h3>{game.data.title}</h3>
                <p class="tagline">{game.data.tagline}</p>
                <p>{game.data.summary}</p>
                {game.data.releaseWindow && <p class="release">{game.data.releaseWindow}</p>}
                <ul>
                  {game.data.highlights.map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              </div>
              <div class="gallery" aria-label={`${game.data.title} concept art`}>
                {game.data.gallery.slice(0, 6).map((item) => (
                  <img src={item.image} alt={item.alt} loading="lazy" />
                ))}
              </div>
            </article>
          ))
        }
      </div>

      <aside class="art-note">
        Concept art shown here includes exploratory AI-generated images. Final game art will be human-directed and
        production-made; if AI is used later, it will be a small, clearly handled part of the overall art process.
      </aside>
    </section>

    <section id="engine" class="section engine-section" aria-labelledby="engine-title">
      <div class="engine-card">
        <div class="engine-copy">
          <p class="eyebrow">Open-source toolchain</p>
          <h2 id="engine-title">Folded Paper Engine</h2>
          <p>
            Folded Paper Engine is Papercraft Games' Blender-to-Godot workflow for creating stylized game spaces and
            interactive mechanics. It lets us tag gameplay in Blender, export standard GLTF, and open playable Godot
            scenes with players, triggers, physics, audio, inventory items, scene metadata, and animation events.
          </p>
          <div class="engine-actions">
            <a class="button primary" href={homeData.fpeUrl} target="_blank" rel="noopener noreferrer">
              Explore FPE
            </a>
            <a
              class="button secondary"
              href="https://github.com/papercraftgames/folded-paper-engine"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </a>
          </div>
        </div>
        <img class="engine-logo" src="/images/fpe-logo.png" alt="Folded Paper Engine" loading="lazy" />
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <img src="/images/gami-kitty.png" alt="Gami Kitty" />
    <div>
      <p>Papercraft Games</p>
      <nav aria-label="Footer links">
        <a href={homeData.itchUrl} target="_blank" rel="noopener noreferrer">Itch.io</a>
        <a href={homeData.fpeUrl} target="_blank" rel="noopener noreferrer">Folded Paper Engine</a>
        <a href="https://github.com/papercraftgames" target="_blank" rel="noopener noreferrer">GitHub</a>
      </nav>
    </div>
  </footer>
</BaseLayout>
